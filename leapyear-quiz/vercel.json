{
  "rewrites": [
    { "source": "/faithdriven", "destination": "/faithdriven.html" },
    { "source": "/brentwood", "destination": "/brentwood.html" },
    { "source": "/results/:token", "destination": "/results.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ]
}
